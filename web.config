<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config for HubAPI under iisnode.

  Prerequisites on the IIS server:
    1. Install Node.js (LTS).
    2. Install iisnode  (https://github.com/Azure/iisnode/releases).
    3. Install URL Rewrite 2.x.
    4. Run `npm ci --omit=dev` and `npm run build` on the server (or copy a
       pre-built dist/ over). The site root must contain dist/index.js.
    5. Set environment variables in iisnode site config (or via web.config
       <appSettings>) — see .env.example for the full list. NEVER commit
       real secrets to web.config; use the IIS Configuration Editor instead.

  Application pool: Integrated mode, .NET CLR Version = "No Managed Code".
-->
<configuration>
  <system.webServer>

    <!-- iisnode hands every request to dist/index.js -->
    <handlers>
      <add name="iisnode" path="dist/index.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Rewrite incoming URLs so they all resolve to the Node entry point.
         WebSocket upgrade requests pass through untouched (iisnode handles them). -->
    <rewrite>
      <rules>
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
            <add input="{REQUEST_URI}" pattern="^/api/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/socket.io/" negate="true" />
          </conditions>
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="dist/index.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode tunables. Adjust for production hardware. -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      watchedFiles="*.js;dist\*.js;web.config"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false" />

    <!-- WebSockets must be enabled in IIS (Server Manager: Enable WebSocket Protocol). -->
    <webSocket enabled="true" />

    <!-- Allow large request payloads (avatar uploads, MOM bodies). -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="2097152" />
      </requestFiltering>
    </security>

    <!-- Hide stack traces in prod. Set devErrorsEnabled=true above when debugging. -->
    <httpErrors errorMode="DetailedLocalOnly" />

  </system.webServer>
</configuration>
