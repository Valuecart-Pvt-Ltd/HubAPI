# Database
DATABASE_URL=postgresql://user:password@localhost:5432/valuecart_mom

# Auth
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Google OAuth — register callback URL as ${SERVER_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth (optional) — register callback as ${SERVER_URL}/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Trello Integration
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token

# Webhook Secrets (leave blank to skip signature verification in development)
READAI_WEBHOOK_SECRET=your_readai_webhook_secret
FIREFLIES_WEBHOOK_SECRET=your_fireflies_webhook_secret

# App — URLs are absolute; CLIENT_URL can be comma-separated for multi-origin CORS
PORT=4000
SERVER_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
COMPANY_DOMAIN=valuecart.com

# Email (SMTP) — used for meeting notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_app_password
