# ─── Database (MSSQL) ────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=karya_dev
DB_USER=karya_dev
DB_PASSWORD=replace_in_local_env
DB_ENCRYPT=true
DB_TRUST_CERT=true
DB_POOL_MAX=20

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT_SECRET is shared with KaaryaAPI so a single login covers both apps (HS256).
JWT_SECRET=replace_with_long_random_string
SESSION_SECRET=replace_with_long_random_string

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Register callback URL as ${SERVER_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth (optional) ──────────────────────────────────────────────
# Register callback URL as ${SERVER_URL}/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Webhook secrets (leave blank to skip signature verification in dev) ─────
READAI_WEBHOOK_SECRET=
FIREFLIES_WEBHOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=4000
SERVER_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
COMPANY_DOMAIN=valuecart.com

# ─── Email (SMTP) — outbound notifications ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Kaarya integration (Phase 3) ────────────────────────────────────────────
# When set, Karya MOM action items create Kaarya cards via this internal URL.
KAARYA_API_URL=http://localhost:5000
