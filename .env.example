NODE_ENV=production
PORT=4000

# ─── Database (MSSQL) ─────────────────────────────────────────────────────────
MSSQL_SERVER=sql.internal.corp
MSSQL_PORT=1433
MSSQL_DATABASE=valuecart_mom
MSSQL_USER=vcm_app
MSSQL_PASSWORD=change-me
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-long-random-string
SESSION_SECRET=change-me
CLIENT_URL=https://mom.internal.corp
COMPANY_DOMAIN=corp.com

# ─── Google OAuth (Calendar + Meet) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://mom.internal.corp/api/auth/google/callback

# ─── Microsoft OAuth (Outlook Calendar) ──────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://mom.internal.corp/api/auth/microsoft/callback

# ─── Trello ───────────────────────────────────────────────────────────────────
TRELLO_API_KEY=
TRELLO_TOKEN=

# ─── Webhook secrets ──────────────────────────────────────────────────────────
READAI_WEBHOOK_SECRET=
FIREFLIES_WEBHOOK_SECRET=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=
