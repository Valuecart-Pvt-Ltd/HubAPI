<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for hosting the Node.js backend via iisnode.
  Requires:
    * Node.js installed on the VM
    * iisnode module installed (https://github.com/Azure/iisnode/releases)
    * URL Rewrite module installed
  Point the IIS site physical path to the repo root (the folder containing this file).
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="src/server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="StaticContent" stopProcessing="true">
          <match url="^(public|static)/.*" />
          <action type="None" />
        </rule>
        <rule name="DynamicContent" stopProcessing="true">
          <match url="/*" />
          <action type="Rewrite" url="src/server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="%ProgramFiles%\nodejs\node.exe"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      node_env="%node_env%"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
